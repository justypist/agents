# Database
DATABASE_URL="postgres://USER:PASSWORD@HOST:5432/DB_NAME?options=-c%20TimeZone%3DAsia%2FShanghai"

# AI
AI_BASE_URL="https://api.openai.com/v1"
AI_API_KEY="sk-xxx"
AI_LANGUAGE_MODEL="gpt-5.4"

# Deploy
DEPLOY_CONN_STR="<user>@<host>:<port>:/path/to/compose.yaml"

# File Storage (OSS / MinIO / S3-Compatible)
OSS_ENDPOINT="http://127.0.0.1:9000"
OSS_REGION="us-east-1"
OSS_BUCKET="agents"
OSS_ACCESS_KEY_ID="minioadmin"
OSS_SECRET_ACCESS_KEY="minioadmin"
OSS_PUBLIC_BASE_URL="https://files.example.com/agents"
OSS_FORCE_PATH_STYLE="true"
# Optional
OSS_KEY_PREFIX="files"
